generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  TENANT
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  phone         String?
  role          Role      @default(TENANT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  ownedProperties     Property[]           @relation("OwnerProperties")
  rentedProperty      Property?            @relation("TenantProperty")
  rentalRequests      RentalRequest[]      @relation("TenantRequests")
  initiatedTerminations TerminationRequest[] @relation("InitiatedTerminations")

  @@map("users")
}

model Property {
  id          String   @id @default(cuid())
  title       String
  address     String
  description String?
  area        Decimal? @db.Decimal(6, 2)
  rooms       Int?
  floor       Int?
  rentPrice   Decimal  @db.Decimal(12, 2)
  status      PropertyStatus @default(AVAILABLE)
  rentStart   DateTime?
  rentEnd     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId  String
  owner    User   @relation("OwnerProperties", fields: [ownerId], references: [id])

  tenantId String? @unique
  tenant   User?  @relation("TenantProperty", fields: [tenantId], references: [id])

  rentalRequests      RentalRequest[]      @relation("PropertyRequests")
  terminationRequests TerminationRequest[] @relation("PropertyTerminations")

  @@index([ownerId])
  @@index([tenantId])
  @@map("properties")
}

enum PropertyStatus {
  AVAILABLE
  RENTED
  MAINTENANCE
}

model RentalRequest {
  id         String        @id @default(cuid())
  status     RequestStatus @default(PENDING)
  message    String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  tenantId   String
  tenant     User          @relation("TenantRequests", fields: [tenantId], references: [id])
  propertyId String
  property   Property      @relation("PropertyRequests", fields: [propertyId], references: [id])

  @@unique([tenantId, propertyId])
  @@index([propertyId])
  @@index([tenantId])
  @@map("rental_requests")
}

model TerminationRequest {
  id         String        @id @default(cuid())
  status     RequestStatus @default(PENDING)
  message    String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  initiatedById String
  initiatedBy   User   @relation("InitiatedTerminations", fields: [initiatedById], references: [id])
  propertyId    String
  property      Property @relation("PropertyTerminations", fields: [propertyId], references: [id])

  @@index([propertyId])
  @@index([initiatedById])
  @@map("termination_requests")
}
